# Application Configuration
NEXT_PUBLIC_APP_NAME=Heuriskein Content Dashboard
NEXT_PUBLIC_APP_VERSION=1.0.0

# API Configuration (for future backend integration)
# NEXT_PUBLIC_API_BASE=https://api.example.com
# API_SECRET_KEY=your_secret_key_here

# Database Configuration (when applicable)
# DATABASE_URL=postgres://user:password@localhost:5432/heuriskein

# Authentication (when implemented)
# NEXTAUTH_SECRET=your_secret_key
# NEXTAUTH_URL=http://localhost:3000

# Third-party Services (for future integrations)
# INSTAGRAM_API_KEY=your_instagram_api_key
# METRICOOL_API_KEY=your_metricool_api_key
# GOOGLE_ANALYTICS_ID=your_ga_id

# Feature Flags
# ENABLE_ADVANCED_ANALYTICS=false
# ENABLE_COMPETITOR_TRACKING=true
